#!/usr/bin/env bash
set -euo pipefail

input=$(cat)
skill_name=$(printf '%s' "$input" | node -e "
let d = '';
process.stdin.on('data', c => d += c);
process.stdin.on('end', () => {
  try { console.log(JSON.parse(d).tool_input?.skill || ''); }
  catch (_error) { console.log(''); }
});
" 2>/dev/null || echo "")

case "$skill_name" in
  superpowers:writing-plans)
    context='DDD Expert reminder: before `$superpowers:writing-plans`, confirm an accepted domain model. If none exists, invoke `$ddd-expert:domain-modeling`; if one exists, invoke `$ddd-expert:design` before planning.'
    ;;
  superpowers:executing-plans|superpowers:subagent-driven-development)
    context='DDD Expert reminder: for development workflow steps, invoke `$ddd-expert:implement` before code edits.'
    ;;
  superpowers:requesting-code-review|superpowers:receiving-code-review)
    context='DDD Expert reminder: for review workflow steps, invoke `$ddd-expert:review` before findings.'
    ;;
  *)
    printf '{}\n'
    exit 0
    ;;
esac

context_json=$(node -e "console.log(JSON.stringify(process.argv[1]))" "$context")

if [ -n "${CLAUDE_PLUGIN_ROOT:-}" ]; then
  printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "PreToolUse",\n    "additionalContext": %s\n  }\n}\n' "$context_json"
else
  printf '{\n  "additional_context": %s\n}\n' "$context_json"
fi
