#!/usr/bin/env bash
set -euo pipefail

input=$(cat)
skill_name=$(printf '%s' "$input" | node -e "
let d='';process.stdin.on('data',c=>d+=c);process.stdin.on('end',()=>{
  try{console.log(JSON.parse(d).tool_input?.skill||'')}
  catch(e){console.log('')}
})
" 2>/dev/null || echo "")

case "$skill_name" in
    superpowers:brainstorming|\
    superpowers:writing-plans|\
    superpowers:executing-plans|\
    superpowers:subagent-driven-development|\
    superpowers:requesting-code-review|\
    superpowers:receiving-code-review)
        ;;
    *)
        printf '{}\n'
        exit 0
        ;;
esac

case "$skill_name" in
    superpowers:requesting-code-review|superpowers:receiving-code-review)
        skill_type="review"
        ;;
    *)
        skill_type="plan"
        ;;
esac

context_json=$(SKILL_TYPE="$skill_type" CLAUDE_PLUGIN_ROOT="${CLAUDE_PLUGIN_ROOT:-}" node -e "
const fs=require('fs'),path=require('path');
const skillType=process.env.SKILL_TYPE||'plan';
const pluginRoot=process.env.CLAUDE_PLUGIN_ROOT||'plugins/superpowers-ddd-architect';
const dir=path.join(pluginRoot,'skills','standards','references');
const files={};
const allowed=f=>f==='database.md'||f.startsWith('ddd-');
try{
  fs.readdirSync(dir).filter(f=>f.endsWith('.md')&&allowed(f)).sort().forEach(f=>{
    files[f]=path.join(dir,f);
  });
}catch(e){}
const sorted=Object.entries(files).sort((a,b)=>{
  if(a[0]==='ddd-risk-router.md')return -1;
  if(b[0]==='ddd-risk-router.md')return 1;
  return a[0].localeCompare(b[0]);
});
if(!sorted.length)process.exit(0);
const entries=[];
for(const [fname,fpath] of sorted){
  try{
    const content=fs.readFileSync(fpath,'utf8');
    let name=fname,description='';
    if(content.startsWith('---')){
      const end=content.indexOf('---',3);
      if(end!==-1){
        for(const line of content.slice(3,end).split('\n')){
          if(line.startsWith('name:'))name=line.slice(5).trim();
          else if(line.startsWith('description:'))description=line.slice(12).trim();
        }
      }
    }
    entries.push('- ['+name+']\n  '+description+'\n  Path: '+fpath);
  }catch(e){}
}
if(!entries.length)process.exit(0);
const header=skillType==='review'
  ?'The following DDD/backend architecture guardrails are available.\nYou MUST read ddd-risk-router.md first when present, then read only the deeper references required by triggered risk cards or the review scope.\n\nIn your review:\n- cite the relevant DDD/backend pattern for each standards-related finding,\n- explain how the code complies or violates that pattern,\n- do not approve code that violates applicable DDD/backend boundaries.'
  :'The following DDD/backend architecture guardrails are available.\nYou MUST read ddd-risk-router.md first when present, then read only the deeper references required by triggered risk cards or the task scope.\n\nIn your response, explicitly state:\n- which DDD/backend patterns apply,\n- which risk cards triggered deeper reading,\n- which important constraints affect your plan or code,\n- which listed patterns are not relevant, if any.\n\nIf a requested change conflicts with a DDD/backend pattern, state the conflict explicitly instead of silently ignoring the pattern.';
const full='====== DDD Architect Standards ======\n'+header+'\n\n'+entries.join('\n\n')+'\n\nFor non-backend work, state that this plugin is not relevant and continue without loading unrelated standards.\n'+'='.repeat(40);
console.log(JSON.stringify(full));
" 2>/dev/null || true)

if [ -z "$context_json" ]; then
    printf '{}\n'
    exit 0
fi

pattern_names=$(printf '%s' "$context_json" | node -e "
let d='';process.stdin.on('data',c=>d+=c);process.stdin.on('end',()=>{
  const s=JSON.parse(d);
  const names=(s.match(/^- \[(.+?)\]/gm)||[]).map(m=>m.replace(/^- \[|\]$/g,''));
  console.log(names.join(', '));
})
" 2>/dev/null || echo "")

if [ -n "$pattern_names" ]; then
    sys_msg=$(node -e "console.log(JSON.stringify('DDD Architect: loaded backend guardrails — ' + process.argv[1]))" "$pattern_names" 2>/dev/null || echo '""')
else
    sys_msg='""'
fi

if [ -n "${CLAUDE_PLUGIN_ROOT:-}" ]; then
    printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "PreToolUse",\n    "additionalContext": %s\n  },\n  "systemMessage": %s\n}\n' "$context_json" "$sys_msg"
else
    printf '{\n  "additional_context": %s,\n  "systemMessage": %s\n}\n' "$context_json" "$sys_msg"
fi
