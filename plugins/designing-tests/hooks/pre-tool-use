#!/usr/bin/env bash
set -euo pipefail

# Parse skill name from stdin JSON.
input=$(cat)
skill_name=$(printf '%s' "$input" | node -e "
let d='';process.stdin.on('data',c=>d+=c);process.stdin.on('end',()=>{
  try{console.log(JSON.parse(d).tool_input?.skill||'')}
  catch(e){console.log('')}
})
" 2>/dev/null || echo "")

case "$skill_name" in
    superpowers:writing-plans)
        tier="planning"
        ;;
    superpowers:executing-plans|\
    superpowers:subagent-driven-development)
        tier="execution"
        ;;
    superpowers:test-driven-development)
        tier="full"
        ;;
    superpowers:verification-before-completion|\
    superpowers:requesting-code-review|\
    superpowers:receiving-code-review|\
    superpowers:finishing-a-development-branch)
        tier="handoff"
        ;;
    *)
        printf '{}\n'
        exit 0
        ;;
esac

PLUGIN_ROOT="${CLAUDE_PLUGIN_ROOT:-$(cd "$(dirname "$0")/.." && pwd)}"
SKILL_DIR="$PLUGIN_ROOT/skills/designing-tests"

if [ "$tier" = "planning" ]; then
    context="====== Test Design: Evidence Choice ======
For code changes, plan verification with Intent / Risk / Evidence before adding tests.

1. Intent: name the requirement source or assumption.
2. Risk: state the observable regression. If there is no observable failure, do not invent a test.
3. Evidence choice: choose test, check, dry-run, smoke, manual, or residual risk.
4. Prefer checked evidence such as build, lint, typecheck, syntax validation, schema validation, dry-run, or smoke when it catches the risk at lower cost.
5. Escalate to real tests for security, data, contract, async, migration/config, or historical incident risks when lighter evidence would miss the failure.
6. Add a hand-off evidence step: tested, checked, skipped/unavailable, and residual risk.
========================================"

    context_json=$(node -e "console.log(JSON.stringify(process.argv[1]))" "$context" 2>/dev/null || echo '""')
    sys_msg='"Test Design: evidence choice planning guidance"'
fi

if [ "$tier" = "execution" ]; then
    context="====== Test Design: Intent / Risk / Evidence ======
When work involves verification:

1. Intent Gate: derive behavior from spec, contract, ADR, issue, acceptance criteria, architecture docs, or a stated assumption.
2. Risk Gate: write 'If <behavior breaks>, users/system observe <failure>'. If this cannot be stated, do not add a test for that surface.
3. Evidence Gate: choose the lowest-cost reliable evidence: test, check, dry-run, smoke, manual, or residual risk.
4. Tests are selected only when they are the narrowest evidence for the stated regression. Explain why lighter evidence would miss the failure.
5. Architecture docs: verify architecture design goals and residual risk, not every diagram arrow.
6. Integration claims require real risky collaborators; mocked risky internals make the test shallow/fake.
7. Hand-off evidence reports tested, checked, skipped/unavailable, and residual risk.

For full guidance, invoke designing-tests:designing-tests.
=================================================="

    context_json=$(node -e "console.log(JSON.stringify(process.argv[1]))" "$context" 2>/dev/null || echo '""')
    sys_msg='"Test Design: evidence choice execution guidance"'
fi

if [ "$tier" = "handoff" ]; then
    context="====== Test Design: EVIDENCE HAND-OFF ======
Before claiming behavior is complete, fixed, reviewed, or ready:

1. Report tested evidence: tests/commands that protect stated risks.
2. Report checked evidence: build, lint, typecheck, syntax/schema validation, dry-run, or smoke.
3. Name skipped/unavailable/flaky/unrun checks and the residual risk they leave.
4. Do not count skipped integration/E2E tests or unavailable services as passing evidence.
5. If a risky behavior was not tested, explain why checked evidence is sufficient or state the residual risk.

For the full rubric, invoke designing-tests:designing-tests and read references/handoff-gate.md.
========================================"

    context_json=$(node -e "console.log(JSON.stringify(process.argv[1]))" "$context" 2>/dev/null || echo '""')
    sys_msg='"Test Design: evidence hand-off gate"'
fi

if [ "$tier" = "full" ]; then
    context=""

    if [ -f "$SKILL_DIR/SKILL.md" ]; then
        content=$(node -e "
const fs=require('fs');
const raw=fs.readFileSync(process.argv[1],'utf8');
let body=raw;
if(raw.startsWith('---')){
  const end=raw.indexOf('---',3);
  if(end!==-1) body=raw.slice(end+3).trim();
}
console.log(body);
" "$SKILL_DIR/SKILL.md" 2>/dev/null || true)
        if [ -n "$content" ]; then
            context="$content"
        fi
    fi

    ref_dir="$SKILL_DIR/references"
    if [ -d "$ref_dir" ]; then
        for ref in "$ref_dir"/*.md; do
            [ -f "$ref" ] || continue
            summary=$(node -e "
const fs=require('fs');
const raw=fs.readFileSync(process.argv[1],'utf8');
let body=raw;
if(raw.startsWith('---')){
  const end=raw.indexOf('---',3);
  if(end!==-1) body=raw.slice(end+3).trim();
}
const lines=body.split('\n');
let title='';
for(const l of lines){
  if(l.startsWith('#')){title=l.replace(/^#+\s*/,'');break;}
}
console.log('- ['+title+'] Reference: '+process.argv[1]);
" "$ref" 2>/dev/null || true)
            if [ -n "$summary" ]; then
                context="$context
$summary"
            fi
        done
    fi

    if [ -z "$context" ]; then
        printf '{}\n'
        exit 0
    fi

    context_json=$(node -e "console.log(JSON.stringify(process.argv[1]))" "$context" 2>/dev/null || echo '""')
    sys_msg='"Test Design: loaded full evidence choice guidance"'
fi

if [ -n "${CLAUDE_PLUGIN_ROOT:-}" ]; then
    printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "PreToolUse",\n    "additionalContext": %s\n  },\n  "systemMessage": %s\n}\n' "$context_json" "$sys_msg"
else
    printf '{\n  "additional_context": %s,\n  "systemMessage": %s\n}\n' "$context_json" "$sys_msg"
fi

exit 0
