{
  "id": "event-storming-missing-authority",
  "phase": "event-storming",
  "suites": ["smoke", "full"],
  "sandbox": "workspace-write",
  "prompt": "prompt.md",
  "workspace": "workspace",
  "dialogue": {
    "answer": "answer.md",
    "first_turn": {
      "completion": ["needs_clarification"],
      "questions": {
        "min": 1,
        "max": 3,
        "contains_any": [
          ["manager", "category manager", "经理", "品类经理"],
          ["approve", "approved", "approval", "批准", "审批"],
          ["fraud", "reject", "rejected", "欺诈", "拒绝", "驳回"],
          ["final catalog price", "recorded price", "old price", "which price", "最终目录价格", "记录价格", "旧价格", "哪个价格"],
          ["authoritative", "authority", "override", "wins", "final fact", "权威", "覆盖", "优先", "最终事实"]
        ],
        "excludes": ["Aggregate", "Repository", "database", "table", "service boundary", "api boundary"]
      },
      "git": {
        "changed": "none",
        "required_paths": [],
        "forbidden_paths": [
          "docs/spec.md",
          "docs/ddd-expert/README.md",
          "docs/ddd-expert/context-map.md",
          "docs/ddd-expert/context/catalog-pricing/model.md"
        ]
      }
    }
  },
  "expect": {
    "completion": ["completed"],
    "review_conclusion": ["not_applicable"],
    "questions": { "min": 0, "max": 0 },
    "routes": { "contains": [], "excludes": ["event-storming", "codify", "guard"] },
    "verdicts": [],
    "forbid_verdicts": [],
    "git": {
      "changed": "some",
      "required_paths": [
        "docs/ddd-expert/README.md",
        "docs/ddd-expert/context-map.md",
        "docs/ddd-expert/context/catalog-pricing/model.md"
      ],
      "allowed_paths": [
        "docs/ddd-expert/README.md",
        "docs/ddd-expert/context-map.md",
        "docs/ddd-expert/context/catalog-pricing/model.md"
      ],
      "forbidden_paths": ["docs/spec.md", "docs/ddd-expert/context/catalog-pricing/design.md"]
    },
    "files": [
      {
        "path": "docs/ddd-expert/README.md",
        "exists": true,
        "forbid_temporary_trace": true,
        "contains": ["# DDD Expert Artifacts", "[Catalog Pricing](context/catalog-pricing/model.md)", "[context-map.md](context-map.md)"],
        "excludes": ["<!--"]
      },
      {
        "path": "docs/ddd-expert/context-map.md",
        "exists": true,
        "forbid_temporary_trace": true,
        "contains": ["# Context Map", "## Global View", "graph LR", "Catalog Pricing", "### Catalog Pricing", "#### Local View", "```text", "| Catalog Pricing |"],
        "excludes": ["<!--", "[U]", "[D]", "Fraud -->", "--> Fraud"]
      },
      {
        "path": "docs/ddd-expert/context/catalog-pricing/model.md",
        "exists": true,
        "forbid_temporary_trace": true,
        "contains": [
          "model_revision: 1",
          "model_status: shape_ready",
          "# Catalog Pricing Domain Model",
          "Seller",
          "Category Manager",
          "Request Price Change",
          "Approve Price Change",
          "Price Change Request",
          "Category Manager Approved",
          "Fraud Cleared",
          "Fraud Rejected",
          "Price Change Accepted",
          "Price Change Rejected",
          "Catalog Price Changed"
        ],
        "contains_any": [
          ["Fraud Rejected is final", "final outcome", "terminal outcome"],
          ["fraud system establishes", "Fraud system establishes", "fraud system is authoritative", "Fraud system is authoritative", "Fraud Rejected is authoritative", "authoritative Fraud Rejected"],
          ["retains the old", "keeps the old", "catalog price remains", "does not change the catalog price"],
          ["cannot override", "may not override", "does not override"],
          ["new Price Change Request", "new request", "fresh request"],
          ["seller", "Seller"],
          ["Catalog Pricing owns", "Catalog Pricing is authoritative", "current catalog price"],
          ["review is pending", "while fraud review is pending", "keeps its old price while"],
          ["requested price ... current catalog price", "makes the requested price the current catalog price", "catalog price changes to the requested price"],
          ["mutually exclusive", "one terminal outcome", "cannot establish both"],
          ["duplicate", "same established outcome", "does not change the catalog again"]
        ],
        "excludes": ["<!--", "Aggregate Root", "Repository", "manager may override Fraud Rejected", "manager approval changes the catalog price after Fraud Rejected", "Category Manager Approved is final"]
      }
    ],
    "checks": [
      {
        "argv": ["node", "/eval/validate-context-map.mjs", "docs/ddd-expert/context-map.md"],
        "exit": 0,
        "timeout_seconds": 30
      }
    ]
  }
}
