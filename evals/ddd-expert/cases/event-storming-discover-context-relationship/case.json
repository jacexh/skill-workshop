{
  "id": "event-storming-discover-context-relationship",
  "phase": "event-storming",
  "suites": ["full"],
  "sandbox": "workspace-write",
  "prompt": "prompt.md",
  "workspace": "workspace",
  "dialogue": {
    "answer": "answer.md",
    "first_turn": {
      "completion": ["needs_clarification"],
      "questions": {
        "min": 1,
        "max": 3,
        "contains_any": [
          ["Registration", "registration", "seat", "报名", "席位"],
          ["Delivery", "delivery", "admit", "admission", "入场", "准入"],
          ["what fact", "which fact", "established fact", "sufficient", "eligible", "什么事实", "哪个事实", "足够", "有资格"],
          ["release", "released", "later change", "撤销", "释放", "后来变化"]
        ],
        "excludes": [
          "which context should be upstream",
          "which context should be downstream",
          "what relationship pattern",
          "Partnership",
          "Shared Kernel",
          "Customer/Supplier",
          "Conformist",
          "database",
          "table",
          "repository",
          "api call"
        ]
      },
      "git": {
        "changed": "none",
        "required_paths": [],
        "forbidden_paths": [
          "docs/story.md",
          "docs/ddd-expert/README.md",
          "docs/ddd-expert/context-map.md",
          "docs/ddd-expert/context/registration/model.md",
          "docs/ddd-expert/context/delivery/model.md"
        ]
      }
    }
  },
  "expect": {
    "completion": ["completed"],
    "review_conclusion": ["not_applicable"],
    "questions": { "min": 0, "max": 0 },
    "routes": { "contains": [], "excludes": ["event-storming", "codify", "guard"] },
    "verdicts": [],
    "forbid_verdicts": [],
    "git": {
      "changed": "some",
      "required_paths": [
        "docs/ddd-expert/context-map.md",
        "docs/ddd-expert/context/registration/model.md",
        "docs/ddd-expert/context/delivery/model.md"
      ],
      "allowed_paths": [
        "docs/ddd-expert/context-map.md",
        "docs/ddd-expert/context/registration/model.md",
        "docs/ddd-expert/context/delivery/model.md"
      ],
      "forbidden_paths": ["docs/story.md", "docs/ddd-expert/README.md"]
    },
    "files": [
      {
        "path": "docs/ddd-expert/context-map.md",
        "exists": true,
        "forbid_temporary_trace": true,
        "contains": ["# Context Map", "graph LR", "registration --> delivery", "Seat Commitment Facts", "Seat Committed", "Seat Released", "### Registration", "### Delivery", "#### Local View", "```text", "-->|"],
        "excludes": ["<!--", "[U]", "[D]", "delivery --> registration"]
      },
      {
        "path": "docs/ddd-expert/context/registration/model.md",
        "exists": true,
        "forbid_temporary_trace": true,
        "contains": ["model_revision: 2", "model_status: shape_ready", "# Registration Domain Model", "Seat Commitment Facts", "Seat Committed", "Seat Released", "Delivery"],
        "contains_any": [["stable registration", "Registration identity"], ["participant", "attendee"], ["workshop"], ["publishes", "published"]],
        "excludes": ["<!--", "Aggregate Root", "Repository"]
      },
      {
        "path": "docs/ddd-expert/context/delivery/model.md",
        "exists": true,
        "forbid_temporary_trace": true,
        "contains": ["model_revision: 2", "model_status: shape_ready", "# Delivery Domain Model", "Seat Commitment Facts", "Seat Committed", "Seat Released", "Registration"],
        "contains_any": [["admission eligibility", "eligible for admission"], ["latest", "current"], ["does not dictate admission", "Delivery owns admission", "Delivery alone owns admission"], ["attendance already recorded", "recorded attendance", "existing attendance"]],
        "excludes": ["<!--", "Aggregate Root", "Repository"]
      }
    ],
    "checks": [
      {
        "argv": ["node", "/eval/validate-context-map.mjs", "docs/ddd-expert/context-map.md"],
        "exit": 0,
        "timeout_seconds": 30
      }
    ]
  }
}
