          "forbid_temporary_trace": true,
          "contains": ["funds --> purchase", "Funds Settled", "#### Local View", "```text", "-->|"],
          "contains_any": [["Funds is authoritative", "Funds owns", "Funds is the sole authority"], ["Purchase consumes", "Purchase accepts", "Purchase translates"]],
          "excludes": ["purchase --> funds", "[U]", "[D]"]
