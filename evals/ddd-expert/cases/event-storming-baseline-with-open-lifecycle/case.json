{
  "id": "event-storming-baseline-with-open-lifecycle",
  "phase": "event-storming",
  "suites": ["full"],
  "sandbox": "workspace-write",
  "prompt": "prompt.md",
  "workspace": "workspace",
  "dialogue": {
    "answer": "answer.md",
    "first_turn": {
      "completion": ["needs_clarification"],
      "questions": {
        "min": 1,
        "max": 3,
        "contains_any": [
          ["Purchase", "commerce operator", "采购", "购买"],
          ["stock check", "stock fails", "inventory check", "库存检查", "库存失败"],
          ["fraud check", "fraud fails", "fraud review", "风控检查", "风控失败"],
          ["who decides", "who records", "which authority", "what decides", "谁决定", "谁记录"],
          ["what fact", "which fact", "what outcome", "resulting fact", "产生什么事实", "什么结果"],
          ["fulfillment", "preparation", "release", "retry", "corrected evidence", "履约", "重试", "更正"]
        ],
        "propositions": [
          {
            "name": "question investigates Purchase authority when either check fails",
            "accepts": [
              "who decides the Purchase outcome when stock or fraud checks fail",
              "does Purchase decide after a failed stock or fraud check",
              "which authority records rejection when either check fails",
              "what decides acceptance when stock or fraud evidence fails"
            ],
            "rejects": [
              "Funds decides whether stock or fraud checks pass",
              "the database decides Purchase acceptance",
              "failed checks do not affect Purchase"
            ]
          },
          {
            "name": "question investigates the failure fact and business consequence",
            "accepts": [
              "what fact is established and whether fulfillment preparation stops",
              "which rejection fact results and what happens to fulfillment",
              "what outcome is recorded and whether retry requires new evidence",
              "what business fact and consequence follow a failed check"
            ],
            "rejects": [
              "no business fact is established",
              "fulfillment always proceeds after a failed check",
              "the failure changes Funds Settled"
            ]
          }
        ],
        "excludes": [
          "transition table",
          "state machine",
          "lifecycle representation",
          "Repository",
          "database",
          "Kafka"
        ]
      },
      "git": {
        "changed": "some",
        "required_paths": [
          "docs/ddd-expert/README.md",
          "docs/ddd-expert/context-map.md",
          "docs/ddd-expert/context/funds/model.md",
          "docs/ddd-expert/context/funds/design.md",
          "docs/ddd-expert/context/purchase/model.md",
          "docs/ddd-expert/context/purchase/design.md"
        ],
