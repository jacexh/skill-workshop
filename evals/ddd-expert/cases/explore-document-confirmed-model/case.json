{
  "id": "explore-document-confirmed-model",
  "phase": "explore",
  "suites": ["full"],
  "sandbox": "workspace-write",
  "prompt": "prompt.md",
  "workspace": "workspace",
  "expect": {
    "completion": ["completed"],
    "review_conclusion": ["not_applicable"],
    "questions": { "min": 0, "max": 0 },
    "routes": { "contains": ["shape"], "excludes": ["codify", "guard"] },
    "verdicts": [],
    "forbid_verdicts": [],
    "git": {
      "changed": "some",
      "required_paths": [
        "docs/ddd-expert/README.md",
        "docs/ddd-expert/context-map.md",
        "docs/ddd-expert/context/inventory/model.md"
      ],
      "allowed_paths": [
        "docs/ddd-expert/README.md",
        "docs/ddd-expert/context-map.md",
        "docs/ddd-expert/context/inventory/model.md"
      ],
      "forbidden_paths": [
        "docs/spec.md",
        "docs/ddd/model.md",
        "docs/ddd-expert/model.md"
      ]
    },
    "files": [
      {
        "path": "docs/ddd-expert/context/inventory/model.md",
        "exists": true,
        "contains": [
          "# Inventory Domain Model",
          "model_revision: 2",
          "Inventory Reservation",
          "Stock Reserved"
        ],
        "excludes": ["CREATE TABLE", "<Bounded Context>", "<!--"],
        "excludes_words": ["Repository", "table"]
      },
      {
        "path": "docs/ddd-expert/README.md",
        "exists": true,
        "contains": [
          "# DDD Expert Artifacts",
          "## Bounded Contexts",
          "context/inventory/model.md",
          "`design.md` lives beside",
          "may be absent until Shape",
          "[context-map.md](context-map.md)"
        ],
        "excludes": ["<Bounded Context>", "<!--", "## Structure", "```text", "|--", "`--"],
        "excludes_words": []
      },
      {
        "path": "docs/ddd-expert/context-map.md",
        "exists": true,
        "contains": [
          "# Context Map",
          "## Global View",
          "Arrow direction: `U -> D` (Upstream model/published-contract influence -> Downstream model). It does not describe runtime call flow.",
          "```mermaid",
          "graph LR",
          "inventory[\"Inventory\"]",
          "### Inventory",
          "- **Core responsibility:**",
          "- **Business authority:**",
          "#### Local View",
          "- No context dependencies."
        ],
        "excludes": ["<Bounded Context>", "<!--"],
        "excludes_words": []
      }
    ],
    "checks": [
      {
        "argv": [
          "node",
          "/eval/validate-context-map.mjs",
          "docs/ddd-expert/context-map.md"
        ],
        "exit": 0,
        "timeout_seconds": 30
      }
    ]
  }
}
