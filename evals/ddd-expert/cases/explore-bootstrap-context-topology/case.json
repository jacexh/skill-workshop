{
  "id": "explore-bootstrap-context-topology",
  "phase": "explore",
  "suites": ["full"],
  "sandbox": "workspace-write",
  "prompt": "prompt.md",
  "workspace": "workspace",
  "expect": {
    "completion": ["checkpointed"],
    "review_conclusion": ["not_applicable"],
    "questions": {
      "min": 1,
      "max": 1,
      "contains_any": [
        ["Funds", "fund", "settlement", "treasury", "资金", "结算"],
        ["confirm*", "settle*", "revers*", "expir*", "expiry", "确认", "结算", "撤销", "过期"]
      ],
      "excludes": [
        "should Purchase",
        "should the purchase",
        "does Purchase",
        "purchase become",
        "fulfillment release"
      ]
    },
    "routes": { "contains": [], "excludes": ["shape", "codify", "guard"] },
    "verdicts": [],
    "forbid_verdicts": [],
    "git": {
      "changed": "some",
      "required_paths": [
        "docs/ddd-expert/README.md",
        "docs/ddd-expert/context-map.md",
        "docs/ddd-expert/context/funds/model.md",
        "docs/ddd-expert/context/purchase/model.md"
      ],
      "forbidden_paths": [
        "docs/stories.md",
        "docs/topology-decision.md",
        "docs/ddd-expert/context/funds/design.md",
        "docs/ddd-expert/context/purchase/design.md"
      ]
    },
    "files": [
      {
        "path": "docs/ddd-expert/README.md",
        "exists": true,
        "contains": [
          "# DDD Expert Artifacts",
          "## Bounded Contexts",
          "context/funds/model.md",
          "context/purchase/model.md",
          "`design.md` lives beside",
          "may be absent until Shape",
          "[context-map.md](context-map.md)"
        ],
        "excludes": ["<!--", "## Structure", "```text", "|--", "`--"],
        "excludes_words": []
      },
      {
        "path": "docs/ddd-expert/context-map.md",
        "exists": true,
        "contains": [
          "# Context Map",
          "## Global View",
          "Arrow direction: `U -> D` (Upstream -> Downstream).",
          "```mermaid",
          "graph LR",
          "funds[\"Funds\"]",
          "purchase[\"Purchase\"]",
          "funds --> purchase",
          "### Funds",
          "### Purchase",
          "### Funds -> Purchase",
          "Published Language"
        ],
        "contains_words": ["Funds", "Purchase", "Settled"],
        "excludes": ["<!--"],
        "excludes_words": ["Repository", "handler"]
      },
      {
        "path": "docs/ddd-expert/context/funds/model.md",
        "exists": true,
        "contains": ["context: \"Funds\"", "model_revision: 1"],
        "contains_words": ["Funds", "Settled", "Purchase"],
        "excludes": ["<!--"],
        "excludes_words": ["Repository", "handler"]
      },
      {
        "path": "docs/ddd-expert/context/purchase/model.md",
        "exists": true,
        "contains": ["context: \"Purchase\"", "model_revision: 1"],
        "contains_words": ["Purchase", "Funds", "Settled"],
        "excludes": ["<!--"],
        "excludes_words": ["Repository", "handler"]
      }
    ],
    "checks": []
  }
}
