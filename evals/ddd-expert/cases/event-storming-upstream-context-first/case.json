{
  "id": "event-storming-upstream-context-first",
  "phase": "event-storming",
  "suites": ["full"],
  "sandbox": "workspace-write",
  "prompt": "prompt.md",
  "workspace": "workspace",
  "dialogue": {
    "answer": "answer.md",
    "first_turn": {
      "completion": ["needs_clarification"],
      "questions": {
        "min": 1,
        "max": 3,
        "contains_any": [
          ["Payment", "支付"],
          ["authorization", "authorized", "capture", "captured", "settlement", "settled", "授权", "扣款", "结算"],
          ["what fact", "which outcome", "when has payment succeeded", "established fact", "什么事实", "哪个结果", "何时支付成功"],
          ["reversal", "reversed", "later corrected", "later changes", "撤销", "冲正", "后续更正", "后来变化"]
        ],
        "excludes": [
          "should order",
          "should the order",
          "does order",
          "does the order",
          "make order",
          "make the order",
          "what makes order",
          "what makes the order",
          "order ready",
          "order readiness",
          "order transition",
          "order become",
          "order becomes",
          "Aggregate",
          "Repository",
          "database"
        ]
      },
      "git": {
        "changed": "none",
        "required_paths": [],
        "forbidden_paths": [
          "docs/story.md",
          "docs/ddd-expert/context-map.md",
          "docs/ddd-expert/context/payment/model.md",
          "docs/ddd-expert/context/order/model.md"
        ]
      }
    }
  },
  "expect": {
    "completion": ["needs_clarification"],
    "review_conclusion": ["not_applicable"],
    "questions": {
      "min": 1,
      "max": 3,
      "contains_any": [
        ["Order", "订单"],
        ["Payment Captured", "Captured", "支付已扣款", "扣款成功"],
        ["Payment Reversed", "Reversed", "支付已撤销", "扣款撤销"],
        ["what does Order", "how does Order react", "when does Order", "what happens to Order", "fulfillment", "Order 如何", "Order 何时", "订单如何", "订单何时", "履约"]
      ],
      "excludes": [
        "which Aggregate",
        "state machine or fact timeline",
        "Repository",
        "database",
        "outbox",
        "Kafka"
      ]
    },
    "routes": { "contains": [], "excludes": ["event-storming", "codify", "guard"] },
    "verdicts": [],
    "forbid_verdicts": [],
    "git": {
      "changed": "some",
      "required_paths": [
        "docs/ddd-expert/context-map.md",
        "docs/ddd-expert/context/payment/model.md",
        "docs/ddd-expert/context/order/model.md"
      ],
      "allowed_paths": [
        "docs/ddd-expert/context-map.md",
        "docs/ddd-expert/context/payment/model.md",
        "docs/ddd-expert/context/order/model.md"
      ],
      "forbidden_paths": ["docs/story.md", "docs/ddd-expert/README.md"]
    },
    "files": [
      {
        "path": "docs/ddd-expert/context-map.md",
        "exists": true,
        "forbid_temporary_trace": true,
        "contains": ["# Context Map", "payment --> order", "Payment Capture Facts", "Payment Captured", "Payment Reversed", "### Payment", "### Order", "#### Local View", "```text", "-->|"],
        "excludes": ["<!--", "[U]", "[D]", "order --> payment"]
      },
      {
        "path": "docs/ddd-expert/context/payment/model.md",
        "exists": true,
        "forbid_temporary_trace": true,
        "contains": ["model_revision: 2", "model_status: shape_ready", "# Payment Domain Model", "Payment Capture Facts", "Payment Captured", "Payment Reversed", "Order"],
        "contains_any": [["provider confirms", "provider-confirmed"], ["stable payment", "Payment identity"], ["Order identity", "stable order"], ["publishes", "published"]],
        "excludes": ["<!--", "Aggregate Root", "Repository"]
      },
      {
        "path": "docs/ddd-expert/context/order/model.md",
        "exists": true,
        "forbid_temporary_trace": true,
        "contains": ["model_revision: 2", "model_status: evolving", "# Order Domain Model", "Payment Capture Facts", "Payment Captured", "Payment Reversed"],
        "contains_any": [["Payment is authoritative", "Payment-owned", "Payment owns"], ["Order owns", "Order remains authoritative", "Order alone decides"], ["unresolved", "HotSpot", "not yet established", "remains open"]],
        "excludes": ["<!--", "Aggregate Root", "Repository", "Payment Captured makes the Order ready", "Payment Reversed cancels the Order"]
      }
    ],
    "checks": [
      {
        "argv": ["node", "/eval/validate-context-map.mjs", "docs/ddd-expert/context-map.md"],
        "exit": 0,
        "timeout_seconds": 30
      }
    ]
  }
}
