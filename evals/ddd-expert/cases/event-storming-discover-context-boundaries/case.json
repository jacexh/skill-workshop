{
  "id": "event-storming-discover-context-boundaries",
  "phase": "event-storming",
  "suites": ["full"],
  "sandbox": "workspace-write",
  "prompt": "prompt.md",
  "workspace": "workspace",
  "dialogue": {
    "answer": "answer.md",
    "first_turn": {
      "completion": ["needs_clarification"],
      "questions": {
        "min": 1,
        "max": 3,
        "contains_any": [
          ["Workshop Cancelled", "workshop is cancelled", "cancelled workshop", "活动取消", "工作坊取消"],
          ["seat", "registration", "waitlist", "席位", "报名", "候补"],
          ["attendance", "no-show", "delivery evidence", "出席", "缺席", "交付证据"],
          ["earning", "payable", "facilitator pay", "收益", "报酬", "应付"],
          ["what happens", "how does each react", "which consequences", "who decides", "what fact is established", "发生什么", "如何响应", "谁决定", "产生什么事实"]
        ],
        "excludes": [
          "what bounded contexts",
          "which bounded contexts",
          "name the bounded contexts",
          "how many bounded contexts",
          "name the contexts",
          "how many contexts",
          "Aggregate",
          "Repository",
          "database",
          "table",
          "service boundary",
          "api boundary"
        ]
      },
      "git": {
        "changed": "none",
        "required_paths": [],
        "forbidden_paths": [
          "docs/stories.md",
          "docs/ddd-expert/README.md",
          "docs/ddd-expert/context-map.md"
        ]
      }
    }
  },
  "expect": {
    "completion": ["needs_clarification"],
    "review_conclusion": ["not_applicable"],
    "questions": {
      "min": 1,
      "max": 3,
      "contains_any": [
        ["workshop", "seat", "registration", "attendance", "delivery", "earning", "facilitator pay", "活动", "席位", "报名", "出席", "报酬"],
        ["what fact", "which fact", "when", "who", "what happens", "triggers", "sufficient", "affects", "reacts", "什么事实", "何时", "谁", "发生什么", "触发", "影响", "响应"]
      ],
      "excludes": [
        "what bounded contexts",
        "which bounded contexts",
        "name the bounded contexts",
        "how many bounded contexts",
        "name the contexts",
        "how many contexts",
        "Aggregate",
        "database",
        "table",
        "repository",
        "service boundary",
        "api boundary"
      ]
    },
    "routes": { "contains": [], "excludes": ["event-storming", "codify", "guard"] },
    "verdicts": [],
    "forbid_verdicts": [],
    "git": {
      "changed": "some",
      "required_paths": [
        "docs/ddd-expert/README.md",
        "docs/ddd-expert/context-map.md",
        "docs/ddd-expert/context/program/model.md",
        "docs/ddd-expert/context/registration/model.md",
        "docs/ddd-expert/context/delivery/model.md",
        "docs/ddd-expert/context/facilitator-pay/model.md"
      ],
      "allowed_paths": [
        "docs/ddd-expert/README.md",
        "docs/ddd-expert/context-map.md",
        "docs/ddd-expert/context/program/model.md",
        "docs/ddd-expert/context/registration/model.md",
        "docs/ddd-expert/context/delivery/model.md",
        "docs/ddd-expert/context/facilitator-pay/model.md"
      ],
      "forbidden_paths": ["docs/stories.md"]
    },
    "files": [
      {
        "path": "docs/ddd-expert/README.md",
        "exists": true,
        "forbid_temporary_trace": true,
        "contains": ["# DDD Expert Artifacts", "Program", "Registration", "Delivery", "Facilitator Pay", "[context-map.md](context-map.md)"],
        "excludes": ["<!--"]
      },
      {
        "path": "docs/ddd-expert/context-map.md",
        "exists": true,
        "forbid_temporary_trace": true,
        "contains": ["# Context Map", "## Global View", "graph LR", "Program", "Registration", "Delivery", "Facilitator Pay", "Workshop Cancellation Facts", "Workshop Cancelled", "program --> registration", "program --> delivery", "program --> facilitator_pay", "#### Local View", "```text", "-->|"],
        "excludes": ["<!--", "[U]", "[D]"]
      },
      {
        "path": "docs/ddd-expert/context/program/model.md",
        "exists": true,
        "forbid_temporary_trace": true,
        "contains": ["model_revision: 1", "model_status: evolving", "# Program Domain Model", "Workshop Cancellation Facts", "Workshop Cancelled"],
        "contains_any": [["program planner", "Program owns", "Program alone", "Program is authoritative"]],
        "excludes": ["<!--", "Aggregate Root", "Repository"]
      },
      {
        "path": "docs/ddd-expert/context/registration/model.md",
        "exists": true,
        "forbid_temporary_trace": true,
        "contains": ["model_revision: 1", "model_status: evolving", "# Registration Domain Model", "Workshop Cancellation Facts", "Workshop Cancelled", "Seat Released"],
        "contains_any": [["waitlist", "waitlisted"], ["stop* promotion", "no promotion", "does not promote"]],
        "excludes": ["<!--", "Aggregate Root", "Repository"]
      },
      {
        "path": "docs/ddd-expert/context/delivery/model.md",
        "exists": true,
        "forbid_temporary_trace": true,
        "contains": ["model_revision: 1", "model_status: evolving", "# Delivery Domain Model", "Workshop Cancellation Facts", "Workshop Cancelled"],
        "contains_any": [["attendance", "no-show"], ["remain* unchanged", "preserv*", "does not erase"], ["no new attendance", "cannot record new attendance", "prevents new attendance"]],
        "excludes": ["<!--", "Aggregate Root", "Repository"]
      },
      {
        "path": "docs/ddd-expert/context/facilitator-pay/model.md",
        "exists": true,
        "forbid_temporary_trace": true,
        "contains": ["model_revision: 1", "model_status: evolving", "# Facilitator Pay Domain Model", "Workshop Cancellation Facts", "Workshop Cancelled", "Earning Revoked"],
        "contains_any": [["accepted delivery evidence", "delivery evidence"], ["remains payable", "still payable", "not revoked"]],
        "excludes": ["<!--", "Aggregate Root", "Repository"]
      }
    ],
    "checks": [
      {
        "argv": ["node", "/eval/validate-context-map.mjs", "docs/ddd-expert/context-map.md"],
        "exit": 0,
        "timeout_seconds": 30
      }
    ]
  }
}
