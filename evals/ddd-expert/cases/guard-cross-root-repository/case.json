{
  "id": "guard-cross-root-repository",
  "phase": "guard",
  "suites": ["smoke", "full"],
  "sandbox": "read-only",
  "prompt": "prompt.md",
  "workspace": "workspace",
  "expect": {
    "completion": ["completed"],
    "review_conclusion": ["violations"],
