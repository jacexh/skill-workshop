{
  "id": "explore-integrated-model-acceptance",
  "phase": "explore",
  "suites": ["full"],
  "sandbox": "workspace-write",
  "prompt": "prompt.md",
  "workspace": "workspace",
  "expect": {
    "completion": ["completed"],
    "review_conclusion": ["not_applicable"],
    "questions": { "min": 0, "max": 0 },
    "routes": { "contains": ["shape"], "excludes": ["codify", "guard"] },
    "verdicts": [],
    "forbid_verdicts": [],
    "git": {
      "changed": "some",
      "required_paths": [
        "docs/ddd-expert/context-map.md",
        "docs/ddd-expert/context/payment/model.md",
        "docs/ddd-expert/context/order/model.md"
      ],
      "forbidden_paths": [
        "docs/story.md",
        "docs/payment-order-boundary.md",
        "docs/ddd-expert/README.md",
        "docs/ddd-expert/context/payment/design.md",
        "docs/ddd-expert/context/order/design.md"
      ]
    },
    "files": [
      {
        "path": "docs/ddd-expert/context-map.md",
        "exists": true,
        "contains": [
          "## Global View",
          "Arrow direction: `U -> D`",
          "graph LR",
          "payment[\"Payment\"]",
          "order[\"Order\"]",
          "payment --> order",
          "#### Local View",
          "#### Downstream Contracts",
          "#### Upstream Dependencies"
        ],
        "contains_words": ["Payment", "Order", "Captured", "Evidence"],
        "excludes": ["<!--", "## Relationships", "<->"],
        "excludes_words": []
      },
      {
        "path": "docs/ddd-expert/context/payment/model.md",
        "exists": true,
        "contains": ["model_revision: 2", "Order"],
        "contains_words": ["Payment", "Captured"],
        "excludes": ["CREATE TABLE", "<!--"],
        "excludes_words": ["Repository", "handler"]
      },
      {
        "path": "docs/ddd-expert/context/order/model.md",
        "exists": true,
        "contains": ["model_revision: 2"],
        "contains_words": ["Payment", "Captured", "Evidence"],
        "excludes": ["CREATE TABLE", "<!--"],
        "excludes_words": ["Repository", "handler"]
      }
    ],
    "checks": [
      {
        "argv": [
          "node",
          "/eval/validate-context-map.mjs",
          "docs/ddd-expert/context-map.md"
        ],
        "exit": 0,
        "timeout_seconds": 30
      }
    ]
  }
}
