{
  "id": "event-storming-missing-model-fact",
  "phase": "event-storming",
  "suites": ["smoke", "full"],
  "sandbox": "workspace-write",
  "prompt": "prompt.md",
  "workspace": "workspace",
  "dialogue": {
    "answer": "answer.md",
    "first_turn": {
      "completion": ["needs_clarification"],
      "questions": {
        "min": 1,
        "max": 3,
        "contains_any": [
          ["create", "created", "Order", "创建", "订单"],
          ["Payment Attempt", "payment", "capture", "支付尝试", "支付", "扣款"],
          ["partial failure", "Order Paid", "captured first", "fails after", "部分失败", "订单已支付", "先扣款", "之后失败"],
          ["duplicate", "retry", "no-double-charge", "charged twice", "重复", "重试", "重复扣款"],
          ["reverse", "reversal", "who may", "authority", "撤销", "冲正", "谁可以", "权威"]
        ],
        "excludes": [
          "one MySQL transaction",
          "which database transaction",
          "transaction isolation",
          "two-phase commit",
          "outbox",
          "Kafka",
          "Repository"
        ]
      },
      "git": {
        "changed": "none",
        "required_paths": [],
        "forbidden_paths": [
          "docs/spec.md",
          "docs/ddd-expert/README.md",
          "docs/ddd-expert/context-map.md",
          "docs/ddd-expert/context/order/model.md",
          "docs/ddd-expert/context/order/design.md",
          "docs/ddd-expert/context/payment/model.md",
          "docs/ddd-expert/context/payment/design.md"
        ]
      }
    }
  },
  "expect": {
    "completion": ["completed"],
    "review_conclusion": ["not_applicable"],
    "questions": { "min": 0, "max": 0 },
    "routes": { "contains": [], "excludes": ["event-storming", "codify", "guard"] },
    "verdicts": [],
    "forbid_verdicts": [],
    "git": {
      "changed": "some",
      "required_paths": [
        "docs/ddd-expert/README.md",
        "docs/ddd-expert/context-map.md",
        "docs/ddd-expert/context/order/model.md",
        "docs/ddd-expert/context/order/design.md",
        "docs/ddd-expert/context/payment/model.md",
        "docs/ddd-expert/context/payment/design.md"
      ],
      "allowed_paths": [
        "docs/ddd-expert/README.md",
        "docs/ddd-expert/context-map.md",
        "docs/ddd-expert/context/order/model.md",
        "docs/ddd-expert/context/order/design.md",
        "docs/ddd-expert/context/payment/model.md",
        "docs/ddd-expert/context/payment/design.md"
      ],
      "forbidden_paths": ["docs/spec.md"]
    },
    "files": [
      {
        "path": "docs/ddd-expert/README.md",
        "exists": true,
        "forbid_temporary_trace": true,
        "contains": ["# DDD Expert Artifacts", "[Order](context/order/model.md)", "[Payment](context/payment/model.md)", "[context-map.md](context-map.md)"],
        "excludes": ["<!--"]
      },
      {
        "path": "docs/ddd-expert/context-map.md",
        "exists": true,
        "forbid_temporary_trace": true,
        "contains": ["# Context Map", "## Global View", "graph LR", "Payment", "Order", "Payment Outcome Facts", "Payment Captured", "Payment Reversed", "#### Local View", "```text", "-->|"],
        "contains_any": [["payment --> order", "payment_context --> order_context"]],
        "excludes": ["<!--", "[U]", "[D]", "order --> payment"]
      },
      {
        "path": "docs/ddd-expert/context/payment/model.md",
        "exists": true,
        "forbid_temporary_trace": true,
        "contains": ["model_revision: 1", "model_status: shape_ready", "# Payment Domain Model", "Payment Attempt", "Payment Attempt ID", "Requested", "Captured", "Failed", "Reversed", "Capture Payment", "Reverse Payment", "Payment Captured", "Payment Failed", "Payment Reversed", "Finance Operator"],
        "contains_any": [
          ["independent identity", "own identity", "identified by Payment Attempt ID"],
          ["independent lifecycle", "owns its lifecycle", "Payment owns the lifecycle"],
          ["no-double-charge", "never captures twice", "cannot capture twice", "at most one capture"],
          ["duplicate", "retry", "same established outcome", "existing outcome"],
          ["partial failure", "Order cannot", "Order fails"],
          ["authoriz* reversal", "authority to reverse", "may reverse"],
          ["publishes", "published"],
          ["stable Order", "Order identity"],
          ["user-operation key", "operation identity"]
        ],
        "excludes": ["<!--", "Repository", "MySQL", "one transaction"]
      },
      {
        "path": "docs/ddd-expert/context/order/model.md",
        "exists": true,
        "forbid_temporary_trace": true,
        "contains": ["model_revision: 1", "model_status: shape_ready", "# Order Domain Model", "Customer", "Place Paid Order", "Order Payment Pending", "Payment Outcome Facts", "Payment Captured", "Payment Failed", "Payment Reversed", "Record Order Paid", "Order Paid", "Order Payment Failed", "Paid Order Completion Failed", "Order Payment Reversed"],
        "contains_any": [
          ["Payment is authoritative", "Payment-owned", "Payment owns"],
          ["may precede Order Paid", "before Order Paid", "Captured first"],
          ["Order owns", "Order is authoritative", "Order alone decides"],
          ["partial failure", "cannot be marked Paid", "fails before Order Paid"],
          ["fulfillment may", "fulfillment can begin", "permits fulfillment"],
          ["fulfillment does not begin", "remains unavailable for fulfillment", "blocks fulfillment"],
          ["Finance Operator", "Authorize Payment Reversal"],
          ["same operation", "same user-operation key", "operation identity"]
        ],
        "excludes": ["<!--", "Repository", "MySQL", "one transaction"]
      },
      {
        "path": "docs/ddd-expert/context/payment/design.md",
        "exists": true,
        "contains": ["based_on_model_revision: 1", "design_status: codify_ready", "# Payment Tactical Design", "## Model Realization", "Payment Attempt", "Capture Payment", "Reverse Payment", "Payment Captured", "Payment Failed", "Payment Reversed", "Finance Operator"],
        "contains_any": [
          ["Aggregate Root", "Payment Attempt Aggregate"],
          ["no-double-charge", "never captures twice", "at most one capture"],
          ["duplicate", "retry", "same established outcome"],
          ["Reverse Payment", "reversal"]
        ],
        "excludes": ["<!--", "design_status: evolving", "MySQL", "one transaction"]
      },
      {
        "path": "docs/ddd-expert/context/order/design.md",
        "exists": true,
        "contains": ["based_on_model_revision: 1", "design_status: codify_ready", "# Order Tactical Design", "## Model Realization", "Place Paid Order", "Order Payment Pending", "Payment Outcome Facts", "Payment Captured", "Payment Failed", "Payment Reversed", "Record Order Paid", "Order Paid", "Order Payment Failed", "Paid Order Completion Failed", "Order Payment Reversed", "Finance Operator"],
        "contains_any": [
          ["Process Manager", "process manager", "Policy", "policy"],
          ["partial failure", "compensat*", "Reverse Payment"],
          ["Payment may precede", "before Order Paid", "Captured first"],
          ["fulfillment may", "fulfillment can begin", "permits fulfillment"],
          ["fulfillment does not begin", "remains unavailable for fulfillment", "blocks fulfillment"],
          ["same operation", "same user-operation key", "operation identity"]
        ],
        "excludes": ["<!--", "design_status: evolving", "MySQL", "one transaction"]
      }
    ],
    "checks": [
      {
        "argv": ["node", "/eval/validate-context-map.mjs", "docs/ddd-expert/context-map.md"],
        "exit": 0,
        "timeout_seconds": 30
      }
    ]
  }
}
