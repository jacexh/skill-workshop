              "how a later reversal affects fulfillment readiness",
              "whether a refund or chargeback revokes readiness",
              "what Order does after a later Payment reversal"
            ],
            "rejects": [
              "a later reversal cannot affect Order",
              "Payment Captured is rewritten by reversal",
              "Order must ignore every later Payment outcome"
            ]
          }
        ],
        "excludes": [
