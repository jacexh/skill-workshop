{
  "id": "explore-upstream-context-first",
  "phase": "explore",
  "suites": ["full"],
  "sandbox": "read-only",
  "prompt": "prompt.md",
  "workspace": "workspace",
  "expect": {
    "completion": ["needs_clarification"],
    "review_conclusion": ["not_applicable"],
    "questions": {
      "min": 1,
      "max": 1,
