        "should order",
        "should the order",
        "does order",
        "does the order",
        "make order",
        "make the order",
        "what makes order",
        "what makes the order",
        "order ready",
        "order readiness",
        "order transition",
        "order become",
        "order becomes"
      ]
    },
    "routes": { "contains": [], "excludes": ["shape", "codify", "guard"] },
    "verdicts": [],
    "forbid_verdicts": [],
    "git": { "changed": "none", "required_paths": [], "forbidden_paths": [] },
    "files": [],
    "checks": []
  }
