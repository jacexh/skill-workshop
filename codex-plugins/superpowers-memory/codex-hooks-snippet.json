{
  "version": "1.12.25",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/hooks/codex-runtime.js\" session-start",
            "timeout": 30,
            "statusMessage": "Loading project knowledge"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/hooks/codex-runtime.js\" user-prompt-submit",
            "timeout": 30,
            "statusMessage": "Checking project knowledge workflow"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "apply_patch|mcp__filesystem__.*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/hooks/codex-runtime.js\" pre-tool-use",
            "timeout": 30,
            "statusMessage": "Checking project knowledge write policy"
          }
        ]
      }
    ]
  }
}
